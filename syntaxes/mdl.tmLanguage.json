{
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": "MDL",
    "patterns": [
        {
            "include": "#comments"
        },
        {
            "include": "#strings"
        },
        {
            "include": "#starstrings"
        },
        {
            "include": "#atstrings"
        },
        {
            "include": "#directives"
        },
        {
            "include": "#blockKeywords"
        },
        {
            "include": "#propertyKeywords"
        },
        {
            "include": "#enumLiterals"
        },
        {
            "include": "#keywords"
        }
    ],
    "repository": {
        "comments": {
            "patterns": [
                {
                    "name": "comment.line.double-slash.mdl",
                    "begin": "//",
                    "beginCaptures": {
                        "0": {
                            "name": "punctuation.definition.comment.mdl"
                        }
                    },
                    "end": "\\n"
                }
            ]
        },
        "keywords": {
            "patterns": [
                {
                    "name": "keyword.control.mdl",
                    "match": "(?i)\\b(true|false|on|off|yes|no)\\b"
                }
            ]
        },
        "strings": {
            "name": "string.quoted.double.mdl",
            "begin": "\"",
            "end": "\"",
            "patterns": [
                {
                    "name": "constant.character.escape.mdl",
                    "match": "\\\\."
                }
            ]
        },
        "starstrings": {
            "name": "string.quoted.stardouble.mdl",
            "begin": "\"\\*",
            "end": "\\*\"",
            "patterns": [
                {
                    "name": "constant.character.escape.mdl",
                    "match": "\\\\."
                }
            ]
        },
        "atstrings": {
            "name": "string.quoted.atquoted.mdl",
            "begin": "@@",
            "end": "@@",
            "patterns": [
                {
                    "name": "constant.character.escape.mdl",
                    "match": "\\\\."
                }
            ]
        },
        "directives": {
            "patterns": [
                {
                    "name": "keyword.control.directive.mdl",
                    "match": "^\\s*#(?:ifset|ifnset|include)\\b"
                }
            ]
        },
        "blockKeywords": {
            "patterns": [
                {
                    "name": "entity.name.type.block.mdl",
